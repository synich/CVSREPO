local function b16enc(s)
  local r = s:gsub(".", function(char)
    return string.format("%02x", string.byte(char))
  end)
  return r
end

local function cur_line_no_cr()
  local a = editor:GetCurLine()
  if a:sub(a:len(), a:len()) == "\n" then
    return a:sub(1, a:len()-1)
  else
    return a
  end
end

local M = {b16enc = b16enc, cur_line_no_cr = cur_line_no_cr}
return M

