text
@local DICT_STR = [[
{
  "lua" : {"fn" : "local function ()\nend"},
  "fnl" : {"fn" : "(fn []\n (let []\n))"}
}
]]
local DICT = JSON.parse(DICT_STR)

local function snip()
  local kw = npp:GetCurrentWord()
  local ft = npp:GetExtPart():sub(2)
  if DICT[ft] then
    local subt = DICT[ft][kw]
    if subt then editor:ReplaceSel(subt) end
  end
end

npp.AddShortcut('snip', 'Ctrl+M', snip)

