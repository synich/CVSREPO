@local function _range()
  local pos = editor.CurrentPos-1  -- avoid (|) strange action
  local ycnt, fcnt, hcnt = 0, 0, 0
  while pos>=0 do
    local ch = editor.CharAt[pos]
    if ch==41 then ycnt=ycnt+1 end
    if ch==93 then fcnt=fcnt+1 end
    if ch==125 then hcnt=hcnt+1 end
    -- find lonely left pair then break
    if ch==40 then ycnt=ycnt-1 if ycnt<0 then break end end
    if ch==91 then fcnt=fcnt-1 if fcnt<0 then break end end
    if ch==123 then hcnt=hcnt-1 if hcnt<0 then break end end
    pos = pos -1
  end
  if pos <0 then print("Error no match brace") return end
  local epos = editor:BraceMatch(pos, 0) +1
  return pos, epos
end

local function selectBrace()
  local pos, epos = _range()
  editor:SetSel(pos, epos)
end

local function innerBrace()
  local pos, epos = _range()
  editor:SetSel(pos+1, epos-1)
end

local function deal_outer(txt)
  editor:ReplaceSel(string.sub(txt, 2, -2))
end

local function sexp_op()
  local txt, tlen = editor:GetSelText()
  if tlen then
    deal_outer(txt)
  else
    selectBrace()
  end
end

npp.AddShortcut('SexpOp', 'Ctrl+E', sexp_op)
npp.AddShortcut('InnerBrace', 'Ctrl+Alt+E', innerBrace)


--------------------- vim cmd ---------------------
local function wrapPair(c)
  local t = editor:GetSelText()
  if c == "(" then
    t = fmtf("(%s)", t)
  elseif c == "[" then
    t = fmtf("[%s]", t)
  elseif c == "{" then
    t = fmtf("{%s}", t)
  elseif c == "'" then
    t = fmtf("'%s'", t)
  elseif c == '"' then
    t = fmtf('"%s"', t)
  else
    print(fmtf("unknown char: %s", c))
  end
  editor:ReplaceSel(t)
end

local function excVimCmd()
  local cmd = my_ext.inputbox("cmd: y[wrap char]")
  if "y" == cmd:at(1) then
    wrapPair(cmd:at(2))
  else
    print(fmtf("unknown cmd: %s", cmd))
  end
end

npp.AddShortcut('excVimCmd', 'Ctrl+Alt+W', excVimCmd)

