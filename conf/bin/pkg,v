@use a tricky way rewrite usage
@
text
@#!/bin/bash
# A tool for managing packages, Warp for Debian/Arch/CentOS/Alpine package manager in same way
# Usage: pkg command [arguments]
# Commands:
#   files <packages>
#   add/install <packages>
#   list-installed/has-installed
#   reinstall <packages>
#   search <query>
#   show/info <packages>
#   uninstall/rm/del <packages>
#   update /*just renew metadata*/
#   upgrade /*make soft newer*/
#   belong <file>

set -e -u

show_help() {
    sed -ne '/^#/!q;s/.\{1,2\}//;1d;p' < "$0"
	exit 1
}

check_pkgcache() {
	if [ -z "$(find /data/data/com.termux/files/usr/var/cache/apt/pkgcache.bin -mmin -5)" ]; then
		apt update
	fi
}

if [ $# = 0 ]; then
	show_help
fi

#choose what pkg in system
whatpkg=none
if [ -x "$(command -v apk)" ]; then
    whatpkg=apk
elif [ -x "$(command -v apt)" ]; then
    whatpkg=apt
elif [ -x "$(command -v pacman)" ]; then
    whatpkg=pacman
elif [ -x "$(command -v rpm)" ]; then
    whatpkg=rpm
fi

if [ $whatpkg = none ]; then
    echo "can't found any package in your system"
fi

function pkgapt() {
  CMD=$1
  shift 1
case "$CMD" in
	f*) dpkg -L "$@@";;
	he*) show_help;;
	add|ins*)  apt install "$@@";;
	list-i*|ha*) apt list --installed ;;
	rei*) apt install --reinstall "$@@";;
	se*)  apt search "$@@";;
	sh*|inf*) apt show "$@@";;
	un*|rm|del*) apt remove "$@@";;
	upd*) apt update ;;
	upg*) apt full-upgrade "$@@";;
    b*) dpkg-query -S "$@@";;
	*) echo "Unknown command: '$CMD' (run 'pkg help' for usage information)"; exit 1;;
esac
}

function pkgpacman() {
  CMD=$1
  shift 1
case "$CMD" in
	f*) pacman -Ql "$@@";;
	he*) show_help;;
	add|ins*) pacman -S "$@@";;
	list-i*|ha*) pacman -Qv ;;
	rei*) echo "Unsupport this command in this package system";;
	se*) pacman -Ss "$@@";;
	sh*|inf*) pacman -Qii "$@@";;
	un*|rm|del*) pacman -Rs "$@@";;
	up*) pacman -Syu "$@@";;
    b*) pacman -Qo "$@@";;
	*) echo "Unknown command: '$CMD' (run 'pkg help' for usage information)"; exit 1;;
esac
}

function pkgapk() {
  CMD=$1
  shift 1
case "$CMD" in
	f*) apk info -L "$@@";;
	he*) show_help;;
	add|ins*) apk add "$@@";;
	list-i*|ha*) apk list -I;;
	rei*) echo "Unsupport this command in this package system";;
	se*) apk search "$@@";;
	sh*|inf*) apk info "$@@";;
	un*|rm|del*) apk del "$@@";;
	up*) apk update; apk upgrade "$@@";;
    b*) apk info -W "$@@";;
	*) echo "Unknown command: '$CMD' (run 'pkg help' for usage information)"; exit 1;;
esac
}

function pkgrpm() {
  CMD=$1
  shift 1
case "$CMD" in
	f*) rpm -ql "$@@";;
	he*) show_help;;
	add|ins*) yum install "$@@";;
	list-i*|ha*) rpm -qa;;
	rei*) yum reinstall "$@@";;
	se*) yum search "$@@";;
	sh*|inf*) rpm -qi "$@@";;
	un*|rm|del*) rpm -e "$@@";;
	up*) yum update "$@@";;
    b*) rpm -qf "$@@";;
	*) echo "Unknown command: '$CMD' (run 'pkg help' for usage information)"; exit 1;;
esac
}

pkg$whatpkg $@@

@


