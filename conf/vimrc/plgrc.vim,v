@" Modeline and Notes {
" vim: set sw=4 ts=4 sts=4 et tw=78 foldmarker={,} foldlevel=0 foldmethod=marker :
" }

let s:syndic = {'python':'python3', 'sh':'bash', 'lua':'lua', 'scheme':'stklos',}

" ScriptRunTool {

    " default show quickfix window. silent run if has more argument
    function! s:runcmd(cmd, ...)
      if v:version >= 800
          execute 'AsyncRun '.a:cmd
          if a:0==0 && !MvcfCheckQuickfix()
              execute 'copen'
          endif
      else
          execute 'Shell '.a:cmd
      endif
    endfunction

    " refreshtags at top dir
    function! s:refreshtags()
       wall
       let l:Curr_dir=getcwd()
       let i = 1
       while i < 10
          if filereadable("tags")
            call <SID>runcmd('ctags -R', 'silent')
            "--fields=+lS  cscope -Rbkq
            return
          else
            lcd ..
            let i += 1
          endif
       endwhile
       exec 'cd '.l:Curr_dir
       "force buffer reload tags
       edit %
    endfunction

    nnoremap <F12> <esc>:call <SID>refreshtags()<cr>
    inoremap <F12> <esc>:call <SID>refreshtags()<cr>

    function! s:chooseExecutor()
      let l:ft = &filetype
      let l:cmd = ''
      for [k, v] in items(s:syndic)
          if k ==? l:ft
              let l:cmd = v | break
          endif
      endfor
      return l:cmd
    endfunction

    function! s:runcurrentscript(hasarg)
      let l:cmd = s:chooseExecutor()
      if '' == l:cmd
          echo 'runscript cannot recognize this filetype!'
          return
      endif
      let l:arg = ''
      if a:hasarg
        let l:arg = input('Arguments: ')
      endif
      execute 'write'
      call <SID>runcmd(l:cmd.' % '.l:arg)
    endfunction
    nnoremap <Plug>(run-script-noarg)  :call <SID>runcurrentscript(0)<CR>
    nnoremap <Plug>(run-script-onearg) :call <SID>runcurrentscript(1)<CR>

    function! s:replConnect()
      let l:scheme_executable = s:chooseExecutor()
      if '' == l:scheme_executable
          return
      endif

      if has('nvim')
        new
        let s:repl_term_id = termopen(l:scheme_executable)
      else
        let s:repl_term_id = term_start(l:scheme_executable)
      endif

      let g:scheme_split_size = get(g:, "scheme_split_size", "default")
      if g:scheme_split_size != "default"
        silent execute "resize " . g:scheme_split_size
      endif

      normal! G
    endfunction

    " run part code in another window by cp<textobj>
    function! s:replEval(type)
      let sel_save = &selection
      let &selection = "inclusive"
      let reg_save = @@@@

      if a:0
        silent exe "normal! `<" . a:type . "`>y"
      elseif a:type == 'line'
        silent exe "normal! '[V']y"
      elseif a:type == 'block'
        silent exe "normal! `[\<C-V>`]y"
      else
        silent exe "normal! `[v`]y"
      endif

      if !exists('s:repl_term_id')
        call s:replConnect()
      end

      if has("nvim")
        call jobsend(s:repl_term_id, @@@@ . "\n")
      else
        call term_sendkeys(s:repl_term_id, @@@@ . "\n")
      end

      let &selection = sel_save
      let @@@@ = reg_save
    endfunction
    autocmd FileType scheme,lua,python nnoremap <buffer> cp :set opfunc=<SID>replEval<cr>g@@

" }

