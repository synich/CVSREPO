    " Search-File-Keyword {
    function! s:enhancegrep(useinput)
      let l:word = expand("<cword>")
      if type(a:useinput) == 1
          let l:word = a:useinput
      elseif a:useinput == 1
          let l:word = input("Keyword:")
      endif
